        <mxCell id="dFjehSAhcJxhlyv-uPb--10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="230" width="210" x="180" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Design a Hotstar like Application with following requirements:&lt;/b&gt;&lt;div&gt;1. User Login Service&lt;/div&gt;&lt;div&gt;2. Subscribe Service&lt;/div&gt;&lt;div&gt;3. Movie / TV Show Search Service&lt;/div&gt;&lt;div&gt;4. Movie / TV Show Play Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Optimize the application using CDC Pilepine, Highlighting where proxy design pattern can be used.&lt;/div&gt;&lt;div&gt;Use HLS and DASH for specific live/static content playing along with manifest file.&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="550" y="360" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--12" edge="1" parent="1" source="dFjehSAhcJxhlyv-uPb--3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="170" y="1368.5" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--3" parent="1" style="sketch=0;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;align=center;fillColor=#505050;shape=mxgraph.mscae.intune.user_group" value="" vertex="1">
          <mxGeometry height="37" width="50" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--4" parent="1" style="sketch=0;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;align=center;fillColor=#505050;shape=mxgraph.mscae.intune.user_group" value="" vertex="1">
          <mxGeometry height="37" width="50" y="1290" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Functional Requirements&lt;/b&gt;&lt;div&gt;1. User should be able to Login.&lt;/div&gt;&lt;div&gt;2. User should be able to subscribe to different plans provided by the service.&lt;/div&gt;&lt;div&gt;3. User should be able to pay using their preffered payment methods.&lt;/div&gt;&lt;div&gt;4. User should be able to search for specific shows and movies.&lt;/div&gt;&lt;div&gt;5. User should be able to play as well as live stream shows such as cricket matches.&lt;/div&gt;&lt;div&gt;6. Admin can change plans and upload videos.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="530" y="500" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Non-Functional Requirements&lt;/b&gt;&lt;div&gt;1. Service should be able to handle load of ~ 100 Million Users.&lt;br&gt;&lt;div&gt;2. The initial latency to play the video should be ~100 ms.&lt;/div&gt;&lt;div&gt;3. The search service should provide the results in 20 ms.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="390" y="610" as="geometry" />
        </mxCell>
        <mxCell id="dFjehSAhcJxhlyv-uPb--7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;b&gt;Entities -&lt;/b&gt;&lt;/div&gt;&lt;div&gt;1. Video / TV Show / Live Stream&lt;/div&gt;&lt;div&gt;2. User&lt;/div&gt;&lt;div&gt;3. Plan&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;b&gt;API Endpoints&lt;/b&gt;&lt;div&gt;&lt;div&gt;1. User Authentication:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - /login&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - /signup&lt;/div&gt;&lt;div&gt;2. Playing a particular video associated with movie or tv show&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - /play/{video}&lt;/div&gt;&lt;div&gt;3. Live Streaming&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;- /live/{live_id}.m3u8&lt;/div&gt;&lt;div&gt;4. Searching&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; -/search/?q={query}&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="371" y="690" as="geometry" />
        </mxCell>
